<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory android:title="@string/prefs_category_mode">

        <Preference
            android:key="operation_mode_current"
            android:title="@string/prefs_mode_current"
            android:summary="@string/prefs_mode_current_summary" />

        <ListPreference
            android:key="toggle_keycode"
            android:title="@string/prefs_toggle_key"
            android:entries="@array/key_entries"
            android:entryValues="@array/key_values"
            android:defaultValue="4" />

        <SwitchPreferenceCompat
            android:key="toggle_longpress"
            android:title="@string/prefs_toggle_longpress"
            android:defaultValue="true" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/prefs_category_mouse">

        <ListPreference
            android:key="emulation_method"
            android:title="@string/prefs_emulation_method"
            android:entries="@array/emulation_method_entries"
            android:entryValues="@array/emulation_method_values"
            android:defaultValue="ACCESSIBILITY_SERVICE"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            android:key="adb_host"
            android:title="@string/prefs_adb_host"
            android:defaultValue="auto"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            android:key="adb_port"
            android:title="@string/prefs_adb_port"
            android:defaultValue="5555"
            app:useSimpleSummaryProvider="true" />

        <SeekBarPreference
            android:key="mouse_pointer_speed"
            android:title="@string/prefs_mouse_speed"
            android:min="1"
            android:max="50"
            android:defaultValue="10" />

        <ListPreference
            android:key="mouse_cursor_start_position"
            android:title="@string/prefs_mouse_cursor_start_position"
            android:entries="@array/cursor_start_position_entries"
            android:entryValues="@array/cursor_start_position_values"
            android:defaultValue="center" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/prefs_category_key_mapping">

        <ListPreference
            android:key="mouse_key_up"
            android:title="@string/prefs_mouse_key_up"
            android:entries="@array/key_entries"
            android:entryValues="@array/key_values"
            android:defaultValue="19" />

        <ListPreference
            android:key="mouse_key_down"
            android:title="@string/prefs_mouse_key_down"
            android:entries="@array/key_entries"
            android:entryValues="@array/key_values"
            android:defaultValue="20" />

        <ListPreference
            android:key="mouse_key_left"
            android:title="@string/prefs_mouse_key_left"
            android:entries="@array/key_entries"
            android:entryValues="@array/key_values"
            android:defaultValue="21" />

        <ListPreference
            android:key="mouse_key_right"
            android:title="@string/prefs_mouse_key_right"
            android:entries="@array/key_entries"
            android:entryValues="@array/key_values"
            android:defaultValue="22" />

        <ListPreference
            android:key="mouse_key_click"
            android:title="@string/prefs_mouse_key_click"
            android:entries="@array/key_entries"
            android:entryValues="@array/key_values"
            android:defaultValue="23" />

        <ListPreference
            android:key="mouse_key_scroll_up"
            android:title="@string/prefs_mouse_key_scroll_up"
            android:entries="@array/key_entries"
            android:entryValues="@array/key_values"
            android:defaultValue="166" />

        <ListPreference
            android:key="mouse_key_scroll_down"
            android:title="@string/prefs_mouse_key_scroll_down"
            android:entries="@array/key_entries"
            android:entryValues="@array/key_values"
            android:defaultValue="167" />

        <ListPreference
            android:key="mouse_key_scroll_left"
            android:title="@string/prefs_mouse_key_scroll_left"
            android:entries="@array/key_entries"
            android:entryValues="@array/key_values"
            android:defaultValue="89" />

        <ListPreference
            android:key="mouse_key_scroll_right"
            android:title="@string/prefs_mouse_key_scroll_right"
            android:entries="@array/key_entries"
            android:entryValues="@array/key_values"
            android:defaultValue="90" />

        <ListPreference
            android:key="mouse_key_cursor_dpad_toggle"
            android:title="@string/prefs_mouse_key_cursor_dpad_toggle"
            android:entries="@array/key_entries"
            android:entryValues="@array/key_values"
            android:defaultValue="85" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/prefs_category_system">

        <Preference
            android:key="status_accessibility_service"
            android:title="@string/prefs_status_accessibility_service"
            android:summary="@string/prefs_status_unknown"
            android:selectable="false" />

        <SwitchPreferenceCompat
            android:key="background_monitoring_enabled"
            android:title="バックグラウンド監視"
            android:summary="他のアプリ実行中でもキー監視を行います"
            android:defaultValue="true" />

        <Preference
            android:key="open_accessibility_settings"
            android:title="@string/prefs_open_accessibility_settings"
            android:summary="@string/prefs_open_accessibility_settings_summary" />

        <Preference
            android:key="open_app_details_settings"
            android:title="@string/prefs_open_app_details_settings"
            android:summary="@string/prefs_open_app_details_settings_summary" />

        <Preference
            android:key="reset_defaults"
            android:title="@string/prefs_reset_defaults"
            android:summary="@string/prefs_reset_defaults_summary" />

    </PreferenceCategory>

    <PreferenceCategory android:title="動作確認">

        <Preference
            android:key="open_touch_test"
            android:title="タッチ操作テストを開く"
            android:summary="タップ/ダブルタップ/ロングタップを検知して表示します" />

    </PreferenceCategory>

</PreferenceScreen>
