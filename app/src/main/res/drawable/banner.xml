<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <!-- Background: Wide Dark Gradient -->
    <path
        android:pathData="M0,0h320v180h-320z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startY="0"
                android:startX="0"
                android:endY="180"
                android:endX="320"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF1C2329"/>
                <item android:offset="1.0" android:color="#FF000000"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Tech Grid Pattern -->
    <path
        android:strokeColor="#00E5FF"
        android:strokeAlpha="0.1"
        android:strokeWidth="1"
        android:pathData="M40,0v180 M80,0v180 M120,0v180 M160,0v180 M200,0v180 M240,0v180 M280,0v180 M0,45h320 M0,90h320 M0,135h320" />

    <!-- Central Focus: Mouse Cursor -->
    <group
        android:translateX="130"
        android:translateY="40"
        android:scaleX="1.2"
        android:scaleY="1.2">
        
        <!-- Glow Shadow -->
        <path
            android:fillColor="#00E5FF"
            android:fillAlpha="0.2"
            android:pathData="M5,5 L5,57 L17,45 L31,71 L39,65 L25,41 L45,41 Z" />
            
        <!-- Main Cursor -->
        <path
            android:fillColor="#00E5FF"
            android:pathData="M0,0 L0,52 L12,40 L26,66 L34,60 L20,36 L40,36 Z" />
    </group>

    <!-- Decorative Elements: Corner Accents -->
    <path
        android:strokeColor="#00E5FF"
        android:strokeWidth="3"
        android:pathData="M10,40 L10,10 L40,10 M310,140 L310,170 L280,170" />

</vector>